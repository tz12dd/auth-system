# Flask Configuration
FLASK_ENV=development
FLASK_APP=app.py
DEBUG=True

# Security Keys (Generate strong random keys in production)
SECRET_KEY=your-very-secure-random-key-change-this-in-production
JWT_SECRET=your-jwt-secret-key-change-this-in-production

# Database
DATABASE_URL=sqlite:///auth.db

# CORS Configuration
CORS_ORIGINS=http://localhost:8000,http://localhost:5000

# JWT Configuration
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRES=3600
